	column Rolling12Flag = ```
			
			VAR LastFullMonth  = EOMONTH( TODAY(), -1 )     // e.g. 6/30/2025
			VAR FirstFullMonth = EDATE( LastFullMonth, -11 ) // e.g. 7/1/2024
			RETURN
			  IF(
			    '___REMU'[PeriodDate] >= FirstFullMonth
			    && '___REMU'[PeriodDate] <= LastFullMonth,
			    1,
			    0
			  )
			
			```
		formatString: 0
