table ___REMU
	lineageTag: c91cd10d-88e9-46d5-8367-b4e43b6dda01

	measure 'REMU Value' = ```
			
			SWITCH(
			  TRUE(),
			
			  // 1) Data‐cell: both Tracked Items & Month in scope
			  ISINSCOPE( REMU[Tracked Items] ) && ISINSCOPE( 'Date'[MonthYear] ),
			    SUM( REMU[Total] ),
			
			  // 2) Row‐total: Tracked Items in scope but no Month
			  ISINSCOPE( REMU[Tracked Items] ) && NOT ISINSCOPE( 'Date'[MonthYear] ),
			    CALCULATE(
			      SUM( REMU[Total] ),
			      ALL( 'Date'[MonthYear] )
			    ),
			
			  // 3) Column‐total: Month in scope but no Tracked Items
			  NOT ISINSCOPE( REMU[Tracked Items] ) && ISINSCOPE( 'Date'[MonthYear] ),
			    CALCULATE(
			      SUM( REMU[Total] ),
			      ALL( REMU[Tracked Items] )
			    ),
			
			  // 4) Grand‐total: neither Tracked Items nor Month in scope
			    CALCULATE(
			      SUM( REMU[Total] ),
			      ALL( REMU ),
			      ALL( 'Date'[MonthYear] )
			    )
			)
			
			```
		formatString: 0
		lineageTag: 5f73cb4d-30e7-4c3e-918d-81db5d34cd42

	measure 'Records & Evidence Subtitle' = ```
			
			"13-Month Overview (" & 'UI'[UI MonthRange 13m] & ")"
			
			```
