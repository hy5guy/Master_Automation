	measure '_Performance Icon' =
			
			VAR isClearanceRow =
			    SELECTEDVALUE('___Det_case_dispositions_clearance'[Closed Case Dispositions]) = "Clearance Percentage"
			VAR curMonth =
			    SELECTEDVALUE('___Det_case_dispositions_clearance'[Month])
			VAR pctText =
			    CALCULATE(
			        SELECTEDVALUE('___Det_case_dispositions_clearance'[Value]),
			        '___Det_case_dispositions_clearance'[Closed Case Dispositions] = "Clearance Percentage",
			        '___Det_case_dispositions_clearance'[Month] = curMonth
			    )
			/* Clean the text: trim, remove NBSP, commas, and the % sign */
			VAR cleanedText =
			    SUBSTITUTE(
			        SUBSTITUTE(
			            SUBSTITUTE(TRIM(pctText), UNICHAR(160), ""),  -- non-breaking space
			        ",", ""),
			    "%", "")
			VAR pctNumRaw = IFERROR(VALUE(cleanedText), BLANK())   -- avoid visual-breaking error
			VAR pct = DIVIDE(pctNumRaw, 100)
			RETURN
			IF(
			    NOT isClearanceRow || ISBLANK(pct),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        pct >= 0.50, "🟢 " & FORMAT(pct, "0.0%"),
			        pct >= 0.45, "🟡 " & FORMAT(pct, "0.0%"),
			        pct >= 0.40, "🟠 " & FORMAT(pct, "0.0%"),
			        pct >= 0.35, "🔴 " & FORMAT(pct, "0.0%"),
			        "🔴 " & FORMAT(pct, "0.0%")
			    )
			)
		lineageTag: 87c087bd-9867-4a26-88dc-859fac840afe

