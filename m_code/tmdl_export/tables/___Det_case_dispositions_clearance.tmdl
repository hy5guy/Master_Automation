	measure 'Clearance Trend' = ```
			
			VAR CurrentClearance = 
			    CALCULATE(
			        SELECTEDVALUE('___Det_case_dispositions_clearance'[Value]),
			        '___Det_case_dispositions_clearance'[Closed Case Dispositions] = "Clearance Percentage"
			    )
			VAR AvgClearance = [Average Clearance Rate]
			RETURN
			IF(
			    ISBLANK(CurrentClearance),
			    BLANK(),
			    IF(
			        CurrentClearance > AvgClearance + 5, "📈 Above Average",
			        IF(
			            CurrentClearance < AvgClearance - 5, "📉 Below Average",
			            "➡️ Average"
			        )
			    )
			)
			
			```
		lineageTag: ce412493-9fab-450a-ac0b-19686a0df5a3

	measure 'Current Quarter Summary' = ```
			
			VAR CurrentDate = MAX('___Det_case_dispositions_clearance'[Date])
			VAR QuarterStart = 
			    DATE(
			        YEAR(CurrentDate),
			        (QUARTER(CurrentDate) - 1) * 3 + 1,
			        1
			    )
			VAR QuarterClearance = 
			    CALCULATE(
			        AVERAGE('___Det_case_dispositions_clearance'[Value]),
			        '___Det_case_dispositions_clearance'[Date] >= QuarterStart,
			        '___Det_case_dispositions_clearance'[Closed Case Dispositions] = "Clearance Percentage"
			    )
			RETURN
			"Q" & QUARTER(CurrentDate) & " " & YEAR(CurrentDate) & 
			" Avg: " & FORMAT(QuarterClearance, "0.0") & "%"
			```
		lineageTag: e294e486-30af-43d1-a1da-95f5a4adfedc

