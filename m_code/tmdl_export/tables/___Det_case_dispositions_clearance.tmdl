	measure 'Debug Measure' =
			
			VAR CurrentMonth = SELECTEDVALUE('___Det_case_dispositions_clearance'[Month])
			VAR CurrentDisposition = SELECTEDVALUE('___Det_case_dispositions_clearance'[Closed Case Dispositions])
			VAR AllValues = CALCULATE(COUNTROWS('___Det_case_dispositions_clearance'))
			VAR ClearanceValues = CALCULATE(COUNTROWS('___Det_case_dispositions_clearance'), '___Det_case_dispositions_clearance'[Closed Case Dispositions] = "Clearance Percentage")
