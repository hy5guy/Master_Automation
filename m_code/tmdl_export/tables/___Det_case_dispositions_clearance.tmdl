table ___Det_case_dispositions_clearance
	lineageTag: 854ea516-fde6-4815-b944-4d976dea4bc9

	measure 'Case Dispositions Subtitle' = ```
			
			VAR MinDate = MIN('___Det_case_dispositions_clearance'[Date])
			VAR MaxDate = MAX('___Det_case_dispositions_clearance'[Date])
			VAR StartMonth = FORMAT(MinDate, "MMM YYYY")
			VAR EndMonth = FORMAT(MaxDate, "MMM YYYY") 
			VAR MonthCount = DATEDIFF(MinDate, MaxDate, MONTH) + 1
			RETURN 
			"Rolling " & MonthCount & "-Month Case Disposition Analysis | " & 
			StartMonth & " through " & EndMonth
			```
		lineageTag: 68a3aea4-c63a-4d1e-958f-8a2de777acb4

	measure 'Month Sort Order' = ```
			
			VAR SelectedMonth = SELECTEDVALUE('___Det_case_dispositions_clearance'[Month_Abbrev])
			VAR SortValue = SELECTEDVALUE('___Det_case_dispositions_clearance'[Sort_Order])
			RETURN 
			IF(ISBLANK(SortValue), 999999, SortValue)
			```
		formatString: 0
		lineageTag: bc601731-63a8-4272-b48a-7b698dae8d38

	measure 'Clearance Rate Color' = ```
			
			VAR ClearanceRate = SELECTEDVALUE('___Det_case_dispositions_clearance'[Value])
			VAR DispositionType = SELECTEDVALUE('___Det_case_dispositions_clearance'[Closed Case Dispositions])
			RETURN
			IF(
			    DispositionType = "Clearance Percentage",
			    SWITCH(
			        TRUE(),
			        ClearanceRate >= 60, "#2E7D32", // Dark Green - Excellent
			        ClearanceRate >= 50, "#4CAF50", // Green - Good  
			        ClearanceRate >= 40, "#FF9800", // Orange - Fair
			        "#F44336" // Red - Needs Improvement
			    ),
			    "#757575" // Gray for non-clearance rows
			)
			```
		lineageTag: 258894f0-3fbb-4a6e-9213-119d3dfe1691

	measure 'Current Month Total Cases' =
			
			CALCULATE(
			    SUM('___Det_case_dispositions_clearance'[Value]),
			    '___Det_case_dispositions_clearance'[Date] = MAX('___Det_case_dispositions_clearance'[Date]),
			    '___Det_case_dispositions_clearance'[Closed Case Dispositions] = "Total Closed Cases This Month"
			)
		lineageTag: b848b656-440a-4826-8284-0559a9f34396

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Performance Icon' = ```
			
			VAR PreviousMonthStart = EOMONTH(TODAY(), -2) + 1
			VAR PreviousMonthEnd = EOMONTH(TODAY(), -1)
			VAR PreviousMonthMMYY = FORMAT(PreviousMonthStart, "MM-yy")
			
			VAR ClearanceRateForPreviousMonth = 
			    CALCULATE(
			        MAX('___Det_case_dispositions_clearance'[Value]),
			        '___Det_case_dispositions_clearance'[Closed Case Dispositions] = "Clearance Percentage",
			        '___Det_case_dispositions_clearance'[Month] = PreviousMonthMMYY,
			        ALL('___Det_case_dispositions_clearance'[Month]),
			        ALL('___Det_case_dispositions_clearance'[Closed Case Dispositions])
			    )
			RETURN
			SWITCH(
			    TRUE(),
			    ClearanceRateForPreviousMonth >= 50, "🟢 " & FORMAT(ClearanceRateForPreviousMonth, "0.0") & "%",
			    ClearanceRateForPreviousMonth >= 45, "🟡 " & FORMAT(ClearanceRateForPreviousMonth, "0.0") & "%", 
			    ClearanceRateForPreviousMonth >= 40, "🟠 " & FORMAT(ClearanceRateForPreviousMonth, "0.0") & "%",
			    ClearanceRateForPreviousMonth >= 35, "🔴 " & FORMAT(ClearanceRateForPreviousMonth, "0.0") & "%",
			    "🔴 " & FORMAT(ClearanceRateForPreviousMonth, "0.0") & "%"
			)
			```
		lineageTag: 310936a9-4d5b-4f35-821c-011e7ab329de

	measure 'MoM Change' = ```
			
			VAR CurrentValue = SELECTEDVALUE('___Det_case_dispositions_clearance'[Value])
			VAR CurrentDate = SELECTEDVALUE('___Det_case_dispositions_clearance'[Date])
			VAR CurrentDisposition = SELECTEDVALUE('___Det_case_dispositions_clearance'[Closed Case Dispositions])
			VAR PreviousMonthDate = EDATE(CurrentDate, -1)
			VAR PreviousValue = 
			    CALCULATE(
			        SELECTEDVALUE('___Det_case_dispositions_clearance'[Value]),
			        '___Det_case_dispositions_clearance'[Date] = PreviousMonthDate,
			        '___Det_case_dispositions_clearance'[Closed Case Dispositions] = CurrentDisposition
			    )
			VAR Change = CurrentValue - PreviousValue
			RETURN
			IF(
			    ISBLANK(PreviousValue) || ISBLANK(CurrentValue),
			    BLANK(),
			    IF(
			        CurrentDisposition = "Clearance Percentage",
			        FORMAT(Change, "+0.0;-0.0") & "pp",
			        FORMAT(Change, "+#,0;-#,0;0")
			    )
			)
			```
		lineageTag: 7f34459e-2d40-4b5e-85ed-d03ad888f9fe

