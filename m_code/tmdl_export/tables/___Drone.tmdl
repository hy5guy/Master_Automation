	measure FormattedValueImproved = ```
			
			VAR m = SELECTEDVALUE( ___Drone[Metric] )
			VAR HasSinglePeriod = HASONEVALUE(___Drone[Period])
			RETURN
			SWITCH(
			    TRUE(),
			    
			    // decimal-hour rows - UPDATED with prefixes
			    m IN {
			        "DFR Activity Flight Time - Calls Responded To (Hours)",
			        "DFR Activity Flight Time - Training Flights (Hours)",
			        "DFR Activity Total Flight Time (Hours)",
			        "Non-DFR Flight Time - Calls Responded To (Hours)",
			        "Non-DFR Flight Time - Training Flights (Hours)",
			        "Non-DFR Total Flight Time (Hours)"
			    },
			        FORMAT( [NumericValue], "0.00" ),
			
			    // count rows - UPDATED with prefixes  
			    m IN {
			        "DFR Activity Total Calls Responded To",
			        "DFR Activity DFR Assisted Arrests",
			        "DFR Activity DFR Deployments that Avoided Dispatching a Patrol Unit",
			        "DFR Activity DFR First on Scene Count",
			        "DFR Activity DFR Shift (Hours)",
			        "Non-DFR Total Calls Responded To",
			        "Non-DFR DFR Assisted Arrests",
			        "Non-DFR DFR Deployments that Avoided Dispatching a Patrol Unit",
			        "Non-DFR DFR First on Scene Count",
			        "Non-DFR DFR Shift (Hours)"
			    },
			        FORMAT( [NumericValue], "0" ),
			
			    // duration rows - EXCLUDE from totals
			    m IN {
			        "DFR Activity AVG Response Times - First on Scene (Hrs:Mins:Secs)",
			        "DFR Activity AVG Response Times - All Calls (Hrs:Mins:Secs)"
			    },
			        IF(
			            HasSinglePeriod,
			            VAR RawValue = SELECTEDVALUE( ___Drone[Value] )
			            VAR CleanValue = SUBSTITUTE(SUBSTITUTE(RawValue, "12/31/1899 ", ""), " AM", "")
			            RETURN
			                IF(
			                    FIND("12/31/1899", RawValue, 1, 0) > 0,
			                    CleanValue,
			                    RawValue
			                ),
			            "--"  // Show dashes in total column
			        ),
			
			    // fallback
			    FORMAT( [NumericValue], "0.00" )
			)
			
			```
		lineageTag: 3f20190a-07e8-47e8-8417-03b0f9879bd7

