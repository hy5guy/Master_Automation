	measure CorrectedTotalValue = ```
			
			VAR CurrentMetric = SELECTEDVALUE(___Drone[Metric])
			VAR IsResponseTime = 
			    CurrentMetric IN {
			        "DFR Activity AVG Response Times - First on Scene (Hrs:Mins:Secs)",
			        "DFR Activity AVG Response Times - All Calls (Hrs:Mins:Secs)"
			    }
			VAR HasSinglePeriod = HASONEVALUE(___Drone[Period])
			RETURN
			    IF(
			        IsResponseTime,
			        IF(
			            HasSinglePeriod,
			            SELECTEDVALUE(___Drone[Value]),
			            "--"
			        ),
			        SUMX(
			            ___Drone,
			            VAR v = TRIM( ___Drone[Value] )
			            VAR CurrentRowMetric = ___Drone[Metric]
			            VAR IsCurrentRowResponseTime = 
			                CurrentRowMetric IN {
			                    "DFR Activity AVG Response Times - First on Scene (Hrs:Mins:Secs)",
			                    "DFR Activity AVG Response Times - All Calls (Hrs:Mins:Secs)"
			                }
