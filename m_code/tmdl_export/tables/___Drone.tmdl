	measure NonDFR_Subtitle =
			
			VAR MinDate = CALCULATE( MIN( ___Drone[PeriodDate] ), ___Drone[Source] = "Non-DFR", ___Drone[Period] <> "Total" )
			VAR MaxDate = CALCULATE( MAX( ___Drone[PeriodDate] ), ___Drone[Source] = "Non-DFR", ___Drone[Period] <> "Total" )
			VAR StartMonth = FORMAT( MinDate, "MMM yyyy" )
			VAR EndMonth = FORMAT( MaxDate, "MMM yyyy" )
			VAR MonthCount = DATEDIFF( MinDate, MaxDate, MONTH ) + 1
			RETURN
			    "Rolling " & MonthCount & "-Month Analysis | " &
			    StartMonth & " through " & EndMonth
		lineageTag: 421b8199-d68d-4dc0-bc04-dfa6db17c5c8

	measure ResponseTimeValue = ```
			
