	measure ResponseTimeTotal = ```
			
			VAR CurrentMetric = SELECTEDVALUE(___Drone[Metric])
			VAR IsResponseTime = 
			    CurrentMetric IN {
			        "DFR Activity AVG Response Times - First on Scene (Hrs:Mins:Secs)",
			        "DFR Activity AVG Response Times - All Calls (Hrs:Mins:Secs)"
			    }
			VAR HasSinglePeriod = HASONEVALUE(___Drone[Period])
			RETURN
			    IF(
			        IsResponseTime,
			        IF(
			            HasSinglePeriod,
			            SELECTEDVALUE(___Drone[Value]),
			            // Calculate average of response times for totals
			            VAR ResponseTimes = 
			                FILTER(
			                    ___Drone,
			                    ___Drone[Metric] = CurrentMetric && 
			                    ___Drone[Value] <> "" && 
			                    ___Drone[Value] <> BLANK()
			                )
			            VAR AvgSeconds = AVERAGEX(
			                ResponseTimes,
			                VAR TimeStr = TRIM(___Drone[Value])
			                VAR FirstColon = FIND(":", TimeStr, 1, 0)
			                VAR SecondColon = FIND(":", TimeStr, FirstColon + 1, 0)
			                VAR Hours = IFERROR(VALUE(LEFT(TimeStr, FirstColon - 1)), 0)
			                VAR Minutes = IFERROR(VALUE(MID(TimeStr, FirstColon + 1, SecondColon - FirstColon - 1)), 0)
			                VAR Seconds = IFERROR(VALUE(RIGHT(TimeStr, LEN(TimeStr) - SecondColon)), 0)
			                RETURN Hours * 3600 + Minutes * 60 + Seconds
			            )
			            VAR AvgHours = INT(AvgSeconds / 3600)
			            VAR AvgMinutes = INT(MOD(AvgSeconds, 3600) / 60)
			            VAR AvgSecs = MOD(AvgSeconds, 60)
			            RETURN FORMAT(AvgHours, "00") & ":" & FORMAT(AvgMinutes, "00") & ":" & FORMAT(AvgSecs, "00")
			        ),
			        SUMX(
			            ___Drone,
			            VAR v = TRIM( ___Drone[Value] )
			            VAR CurrentRowMetric = ___Drone[Metric]
			            VAR IsCurrentRowResponseTime = 
			                CurrentRowMetric IN {
			                    "DFR Activity AVG Response Times - First on Scene (Hrs:Mins:Secs)",
			                    "DFR Activity AVG Response Times - All Calls (Hrs:Mins:Secs)"
			                }
			            VAR IsSameMetric = CurrentRowMetric = CurrentMetric
			            RETURN
			                IF(
			                    IsCurrentRowResponseTime || NOT IsSameMetric,
			                    0,
			                    IFERROR( VALUE(v), 0 )
			                )
			        )
			    )
			```
		lineageTag: 99cf29eb-8184-4308-a514-0605d23dc2fb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

