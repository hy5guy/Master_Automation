	measure 'High Activity Title' = ```
			"STACP High Priority Incidents (>10 Cases)"
			
			```
		lineageTag: 8057dcd2-2d78-4bee-bd6a-63866b5710ac

	measure 'High Activity Subtitle' = ```
			
			VAR PreviousMonthStart = EOMONTH(TODAY(), -2) + 1
			VAR PreviousMonthEnd = EOMONTH(TODAY(), -1)
			VAR PreviousMonthSortOrder = FORMAT(PreviousMonthStart, "yyyyMM")
			VAR StartMonth = FORMAT(PreviousMonthStart, "MMM yyyy")
			VAR EndMonth = FORMAT(PreviousMonthEnd, "MMM yyyy")
			VAR TotalIncidents = 
			    CALCULATE(
			        [High Activity Total],
			        'STACP_High_Activity'[Month_Sort_Order] = PreviousMonthSortOrder
			    )
			VAR CategoryCount = 
			    CALCULATE(
			        DISTINCTCOUNT('STACP_High_Activity'[Tracked Items ]),
			        'STACP_High_Activity'[Month_Sort_Order] = PreviousMonthSortOrder
			    )
			VAR HighestCategory = 
			    CALCULATE(
			        VALUES('STACP_High_Activity'[Tracked Items ]),
			        TOPN(1, 
			            SUMMARIZE(
			                FILTER(
			                    'STACP_High_Activity',
			                    'STACP_High_Activity'[Month_Sort_Order] = PreviousMonthSortOrder
			                ), 
			                'STACP_High_Activity'[Tracked Items ], 
			                "Total", 
			                CALCULATE(
			                    [High Activity Total],
			                    'STACP_High_Activity'[Month_Sort_Order] = PreviousMonthSortOrder
			                )
			            ),
			            [Total], DESC
			        )
			    )
			VAR HighestTotal = 
			    CALCULATE(
			        [High Activity Total],
			        'STACP_High_Activity'[Tracked Items ] = HighestCategory,
			        'STACP_High_Activity'[Month_Sort_Order] = PreviousMonthSortOrder
			    )
			RETURN
			StartMonth & " - " & EndMonth & " | " & 
			FORMAT(TotalIncidents, "#,0") & " Total Incidents | " &
			CategoryCount & " Categories | " &
			"Highest: " & HighestCategory & " (" & FORMAT(HighestTotal, "#,0") & ")"
			```
		formatString: 0
		lineageTag: 21fa9724-d431-45ee-b0fa-2db3e9f11800

