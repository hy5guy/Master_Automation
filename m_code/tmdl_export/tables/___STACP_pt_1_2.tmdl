	measure 'Detective Transfer Summary' =
			
			VAR DetectiveTotal = [Detective Transfer Total]
			VAR STACPTotal = [STACP Core Total]
			VAR GrandTotal = DetectiveTotal + STACPTotal
			RETURN
			"Detective Transfers: " & FORMAT(DetectiveTotal, "#,0") & " | " &
			"STACP Core: " & FORMAT(STACPTotal, "#,0") & " | " &
			"Total: " & FORMAT(GrandTotal, "#,0")
		lineageTag: 867dd3fc-88a4-43ad-9676-705c23b2bd4f

	measure 'Monthly Activity Trend' = ```
			
			VAR _CurrentMonth = SELECTEDVALUE('STACP_High_Activity'[Month_MM_YY])
			VAR _CurrentValue = SUM('STACP_High_Activity'[Value])
			VAR _PrevMonthValue = 
			    CALCULATE(
			        SUM('STACP_High_Activity'[Value]),
			        'STACP_High_Activity'[Month_Sort_Order] = SELECTEDVALUE('STACP_High_Activity'[Month_Sort_Order]) - 1
			    )
			VAR _Change = _CurrentValue - _PrevMonthValue
			VAR _ChangePercent = DIVIDE(_Change, _PrevMonthValue, 0) * 100
			RETURN
			IF(
			    ISBLANK(_PrevMonthValue),
			    FORMAT(_CurrentValue, "#,0"),
			    FORMAT(_CurrentValue, "#,0") & " (" & 
			    IF(_Change >= 0, "+", "") & FORMAT(_Change, "#,0") & ", " &
			    IF(_ChangePercent >= 0, "+", "") & FORMAT(_ChangePercent, "0") & "%)"
			)
			```
		lineageTag: 74b8bcab-739a-471d-ad6a-15cdd389c4f9

	measure 'Current Month Performance' = ```
			
			VAR _LatestMonth = MAX('STACP_High_Activity'[Month_MM_YY])
			VAR _HighActivity = 
			    CALCULATE(
			        SUM('STACP_High_Activity'[Value]),
			        'STACP_High_Activity'[Month_MM_YY] = _LatestMonth
			    )
			VAR _LowActivity = 
			    CALCULATE(
			        SUM('STACP_Low_Activity'[Value]),
			        'STACP_Low_Activity'[Month_MM_YY] = _LatestMonth
			    )
			VAR _DetectiveTransfers = 
			    CALCULATE(
			        SUM('STACP_High_Activity'[Value]),
			        'STACP_High_Activity'[Month_MM_YY] = _LatestMonth,
			        'STACP_High_Activity'[Source_Category] = "Detective Transfer"
			    )
			RETURN
			_LatestMonth & " Summary:" & UNICHAR(10) &
			"High Activity: " & FORMAT(_HighActivity, "#,0") & UNICHAR(10) &
			"Low Activity: " & FORMAT(_LowActivity, "#,0") & UNICHAR(10) &
			"Detective Transfers: " & FORMAT(_DetectiveTransfers, "#,0")
			```
		lineageTag: 5b52cff9-a51e-4464-b370-b4ee1657380a

	measure 'Activity Color' = ```
			
			VAR CurrentValue = SELECTEDVALUE('___STACP_pt_1_2'[Value])
			VAR SourceCategory = SELECTEDVALUE('___STACP_pt_1_2'[Source_Category])
			RETURN
			SWITCH(
			    SourceCategory,
			    "Detective Transfer", 
			        SWITCH(
			            TRUE(),
			            CurrentValue >= 10, "#1B5E20", // Dark green
			            CurrentValue >= 5, "#4CAF50",  // Green
			            CurrentValue >= 2, "#FF9800",  // Orange
			            CurrentValue > 0, "#FFC107",   // Yellow
			            "#E0E0E0"                      // Gray
			        ),
			    "STACP Core",
			        SWITCH(
			            TRUE(),
			            CurrentValue >= 20, "#0D47A1", // Dark blue
			            CurrentValue >= 10, "#1976D2", // Blue
			            CurrentValue >= 5, "#42A5F5",  // Light blue
			            CurrentValue > 0, "#90CAF9",   // Very light blue
			            "#F5F5F5"                      // Light gray
			        ),
			    "#757575" // Default gray
			)
			```
		lineageTag: 98f3eceb-cf19-4599-bf0c-ab0e41b24127

	measure 'Performance Display' =
			
			VAR CurrentValue = SELECTEDVALUE('___STACP_pt_1_2'[Value])
			VAR SourceCategory = SELECTEDVALUE('___STACP_pt_1_2'[Source_Category])
			RETURN
			IF(
			    SourceCategory = "Detective Transfer",
			    SWITCH(
			        TRUE(),
			        CurrentValue >= 10, "🔥 " & CurrentValue,
			        CurrentValue >= 5, "📈 " & CurrentValue,
			        CurrentValue >= 2, "➡️ " & CurrentValue,
			        CurrentValue > 0, FORMAT(CurrentValue, "0"),
			        "—"
			    ),
			    FORMAT(CurrentValue, "0")
			)
		lineageTag: 083c1ebc-610b-4fab-8214-bc4383a9f393

