	measure 'Analysis for Patrol Performance' =
			
			IF(
			    CALCULATE(SUM(___SSOCC_Data[Value]), CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "ANALYSIS FOR PATROL") || CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "PATROL SUPPORT")) >= 90,
			    "🟢 Excellent",
			    IF(
			        CALCULATE(SUM(___SSOCC_Data[Value]), CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "ANALYSIS FOR PATROL") || CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "PATROL SUPPORT")) >= 75,
			        "🟡 Good",
			        "🔴 Needs Attention"
			    )
			)
		lineageTag: f38a34ee-cd07-40bf-a13d-9db135381ad3

