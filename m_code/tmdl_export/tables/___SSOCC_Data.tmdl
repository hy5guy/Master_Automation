	measure 'Technology and Surveillance Percentage' = ```
			
			VAR TechTotal = 
			    CALCULATE(
			        SUM(___SSOCC_Data[Value]),
			        CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "CCTV") ||
			        CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "AVIGILON") ||
			        CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "MONITORING") ||
			        CONTAINSSTRING(UPPER(___SSOCC_Data[Service/Product]), "TAS ALERT")
			    )
			VAR GrandTotal = 
			    SUM(___SSOCC_Data[Value])
			RETURN
			    DIVIDE(TechTotal, GrandTotal, 0) * 100
