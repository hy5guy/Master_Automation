	measure 'Analysis for Detectives Card Title' = ```
			
			VAR CurrentTotal = [Analysis for Detectives Total]
			VAR MinDate = MIN(___SSOCC_Data[Date])
			VAR MaxDate = MAX(___SSOCC_Data[Date])
			VAR StartPeriod = FORMAT(MinDate, "MMM YYYY")
			VAR EndPeriod = FORMAT(MaxDate, "MMM YYYY")
			VAR MonthCount = DATEDIFF(MinDate, MaxDate, MONTH) + 1
			VAR PerformanceLevel = 
			    IF(CurrentTotal >= 12, "🟢 High",
			    IF(CurrentTotal >= 8, "🟡 Good", "🔴 Low"))
			RETURN
			"Analysis for Detectives" & UNICHAR(10) &
			StartPeriod & " - " & EndPeriod & " | " & PerformanceLevel & " Activity" & UNICHAR(10) &
			FORMAT(CurrentTotal, "#,0") & " Total Requests"
			```
		lineageTag: aff5f849-29d9-460c-a03c-617257516cf5

	measure 'Analysis for Patrol Card Title' = ```
			
			VAR CurrentTotal = [Analysis for Patrol Total]
			VAR MinDate = MIN(___SSOCC_Data[Date])
			VAR MaxDate = MAX(___SSOCC_Data[Date])
			VAR StartPeriod = FORMAT(MinDate, "MMM YYYY")
			VAR EndPeriod = FORMAT(MaxDate, "MMM YYYY")
			VAR MonthCount = DATEDIFF(MinDate, MaxDate, MONTH) + 1
			VAR PerformanceLevel = 
			    IF(CurrentTotal >= 15, "🟢 High",
			    IF(CurrentTotal >= 10, "🟡 Good", "🔴 Low"))
			RETURN
			"Analysis for Patrol" & UNICHAR(10) &
			StartPeriod & " - " & EndPeriod & " | " & PerformanceLevel & " Activity" & UNICHAR(10) &
			FORMAT(CurrentTotal, "#,0") & " Total Requests"
			```
		lineageTag: c5c4aed3-6448-4077-a044-62a152a8c5ed

	measure 'Avigilon Flag Review Card Title' = ```
			
			VAR CurrentTotal = [Avigilon Flag Review Total]
			VAR MinDate = MIN(___SSOCC_Data[Date])
			VAR MaxDate = MAX(___SSOCC_Data[Date])
			VAR StartPeriod = FORMAT(MinDate, "MMM YYYY")
			VAR EndPeriod = FORMAT(MaxDate, "MMM YYYY")
			VAR MonthCount = DATEDIFF(MinDate, MaxDate, MONTH) + 1
			VAR PerformanceLevel = 
			    IF(CurrentTotal >= 40, "🟢 High",
			    IF(CurrentTotal >= 25, "🟡 Good", "🔴 Low"))
			VAR AvgPerMonth = DIVIDE(CurrentTotal, MonthCount, 0)
			RETURN
			"Avigilon Flag Review" & UNICHAR(10) &
			StartPeriod & " - " & EndPeriod & " | " & PerformanceLevel & " Activity" & UNICHAR(10) &
			FORMAT(CurrentTotal, "#,0") & " Reviews | " & FORMAT(AvgPerMonth, "0.0") & "/month"
			```
		lineageTag: 122b9f8f-3363-4087-902d-d1ab7ddf0ddf

	measure 'CCTV Site Analysis Card Title' = ```
			
			VAR CurrentTotal = [CCTV Site Analysis Total]
			VAR MinDate = MIN(___SSOCC_Data[Date])
			VAR MaxDate = MAX(___SSOCC_Data[Date])
			VAR StartPeriod = FORMAT(MinDate, "MMM YYYY")
