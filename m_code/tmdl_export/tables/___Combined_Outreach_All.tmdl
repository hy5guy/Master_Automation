	measure 'Prev Month Flag' =
			
			VAR StartPrev =
			    EOMONTH ( TODAY(), -2 ) + 1        -- first day of the prior month
			VAR EndPrev =
			    EOMONTH ( TODAY(), -1 )            -- last day of the prior month
			RETURN
			    IF (
			        MIN ( 'preview_table'[Date] ) >= StartPrev
			            && MAX ( 'preview_table'[Date] ) <= EndPrev,
			        1,
			        0
			    )
		lineageTag: fcc69c01-0cb2-4228-9664-14cf27d53c40

	column IsPrevMonth = ```
			
			VAR PrevMonthNum       = MONTH ( TODAY() ) - 1
			VAR PrevYearAdjustment = IF ( PrevMonthNum = 0, 1, 0 )
			VAR PrevYear           = YEAR ( TODAY() ) - PrevYearAdjustment
			VAR PrevMonth          = IF ( PrevMonthNum = 0, 12, PrevMonthNum )
			VAR StartDate          = DATE ( PrevYear, PrevMonth, 1 )
			VAR EndDate            = EOMONTH ( StartDate, 0 )
			RETURN
			    IF(
			        '___Combined_Outreach_All'[Date] >= StartDate
			            && '___Combined_Outreach_All'[Date] <= EndDate,
			        TRUE(),
