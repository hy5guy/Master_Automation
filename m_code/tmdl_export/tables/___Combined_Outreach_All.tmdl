	measure DateInPrevMonth = ```
			
			VAR PrevMonthNum       = MONTH ( TODAY() ) - 1
			VAR PrevYearAdjustment = IF ( PrevMonthNum = 0, 1, 0 )
			VAR PrevYear           = YEAR ( TODAY() ) - PrevYearAdjustment
			VAR PrevMonth          = IF ( PrevMonthNum = 0, 12, PrevMonthNum )
			VAR StartDate          = DATE ( PrevYear, PrevMonth, 1 )
			VAR EndDate            = EOMONTH ( StartDate, 0 )
			RETURN
			    IF (
			        MIN ( '___Combined_Outreach_All'[Date] ) >= StartDate
			            && MAX ( '___Combined_Outreach_All'[Date] ) <= EndDate,
			        1,
			        0
			    )
			
			```
		formatString: 0
		lineageTag: 70737782-f54c-4056-9d85-04ca9ba87368

	measure SubtitlePrevMonth = ```
			
			VAR MinD = MIN( '___Combined_Outreach_All'[Date] )
			RETURN
			    IF(
			        NOT ISBLANK( MinD ),
			        FORMAT( MinD, "MMMM yyyy" ),
			        ""
			    )
			
			```
		lineageTag: 179369e4-d47e-4126-862d-a24951ded0cf

