	measure 'Course Primary Category' = ```
			
			CALCULATE(
			    SELECTEDVALUE('Policy_Training_Metrics_Qual'[Training_Category]),
			    ALLEXCEPT('Policy_Training_Metrics_Qual', 'Policy_Training_Metrics_Qual'[Course Name])
