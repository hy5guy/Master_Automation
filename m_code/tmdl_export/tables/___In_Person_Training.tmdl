	measure 'Is High Impact Course' = ```
			
			CALCULATE(
			    IF(
			        COUNTROWS(
			            FILTER('Policy_Training_Metrics_Qual', 
			                   'Policy_Training_Metrics_Qual'[High_Impact] = TRUE)
			        ) > 0,
			        "🔥 High Impact",
			        "Standard"
			    ),
			    ALLEXCEPT('Policy_Training_Metrics_Qual', 'Policy_Training_Metrics_Qual'[Course Name])
			)
			
			```
		lineageTag: ea1144d1-a74e-48a9-b364-1e64a2cfffdc

	measure 'In-Person Instances' =
			
			CALCULATE(
			    COUNTROWS('Policy_Training_Metrics_Qual'),
			    'Policy_Training_Metrics_Qual'[Delivery_Type] = "In-Person",
			    ALLEXCEPT('Policy_Training_Metrics_Qual', 'Policy_Training_Metrics_Qual'[Course Name])
			)
		formatString: 0
		lineageTag: a5aa6259-6aee-4bd5-be50-85d22468fe5b

	measure 'Online Instances' =
			
			CALCULATE(
			    COUNTROWS('Policy_Training_Metrics_Qual'),
			    'Policy_Training_Metrics_Qual'[Delivery_Type] = "Online",
			    ALLEXCEPT('Policy_Training_Metrics_Qual', 'Policy_Training_Metrics_Qual'[Course Name])
			)
		formatString: 0
		lineageTag: 1e6e0a75-5aa8-418f-8645-428795533555

	measure 'Course Delivery Mix' = ```
			
			VAR InPersonCount = [In-Person Instances]
			VAR OnlineCount = [Online Instances]
			VAR Total = InPersonCount + OnlineCount
			RETURN
			IF(
			    Total > 0,
			    "In-Person: " & InPersonCount & " | Online: " & OnlineCount & 
			    " (" & FORMAT(DIVIDE(InPersonCount, Total), "0%") & " In-Person)",
			    "No Data"
			)
			```
		lineageTag: a1763c0a-e4d4-4ee9-bc16-627b5225415f

	measure 'Course Training Level' =
			
			CALCULATE(
			    SELECTEDVALUE('Policy_Training_Metrics_Qual'[Training_Level]),
