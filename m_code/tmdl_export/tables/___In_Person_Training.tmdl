table ___In_Person_Training
	lineageTag: ad67753c-c66f-44d7-a8a4-a1aa064bebd7

	measure 'Metrics Qual Title' =
			
			"Training Metrics, Qualifications & Performance Analytics"
		lineageTag: 6c115411-496a-4080-b3ee-1129d0b32c76

	measure 'Metrics Qual Subtitle' = ```
			
			VAR _MinDate = MIN('Policy_Training_Metrics_Qual'[Date])
			VAR _MaxDate = MAX('Policy_Training_Metrics_Qual'[Date])
			VAR _StartMonth = FORMAT(_MinDate, "MMM YYYY")
			VAR _EndMonth = FORMAT(_MaxDate, "MMM YYYY")
			VAR _MonthCount = DATEDIFF(_MinDate, _MaxDate, MONTH) + 1
			VAR _TotalActivity = SUM('Policy_Training_Metrics_Qual'[Value])
			VAR _MetricCount = DISTINCTCOUNT('Policy_Training_Metrics_Qual'[Tracked Items])
			VAR _LastUpdated = FORMAT(TODAY(), "MMM DD, YYYY")
			VAR _QualAttendees = 
			    CALCULATE(
			        SUM('Policy_Training_Metrics_Qual'[Value]),
			        'Policy_Training_Metrics_Qual'[Tracked Items] IN {
			            "Handgun Qual Attendees",
			            "Rifle Qual Attendees", 
			            "Sub-Gun Qual Attendees",
			            "Taser Qual"
			        }
			    )
			VAR _InPersonTotal = 
			    CALCULATE(
			        SUM('Policy_Training_Metrics_Qual'[Value]),
			        'Policy_Training_Metrics_Qual'[Tracked Items] = "Total Attendees In-Person Training"
			    )
			RETURN
			"Rolling " & _MonthCount & "-Month Analysis | " & 
			_StartMonth & " - " & _EndMonth & " | " &
			FORMAT(_QualAttendees, "#,0") & " Qualification Attendees | " &
			FORMAT(_InPersonTotal, "#,0") & " In-Person Total | " &
			_MetricCount & " Metrics Tracked | " &
			"Updated " & _LastUpdated
			```
		lineageTag: 28404bee-2f70-43a7-8862-10a6b7e71625

	measure 'Metrics Total' =
			
			SUM('Policy_Training_Metrics_Qual'[Value])
		lineageTag: f74416cc-ab64-41f8-96d2-faf89a3a812e

