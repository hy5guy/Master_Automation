	measure 'Grand Total Attendees' =
			
			CALCULATE(
			    [Total Training Attendees],
			    ALL('Policy_Training_Metrics_Qual'[Training_Category]),
			    ALL('Policy_Training_Metrics_Qual'[Period])
			)
		lineageTag: 19b4ab9c-d7c9-41fb-a365-c27cfdaa0e79

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Subtitle – In-Person Training' = ```
			
			VAR dPrev = EOMONTH ( TODAY (), -1 )
			VAR m = MONTH ( dPrev )
			VAR y = YEAR ( dPrev )
			VAR mAbbrev =
			    SWITCH ( m,
			        1, "January", 2, "February", 3, "March", 4, "April", 5, "May", 6, "June",
			        7, "July", 8, "August", 9, "September", 10, "October", 11, "November", 12, "December"
			    )
			RETURN
			"Attended Training for " & mAbbrev & " " & y
			
			```
		lineageTag: 15f0015b-f814-4167-8eec-f0ad70b6c5b3

