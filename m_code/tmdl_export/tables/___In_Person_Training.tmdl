			)
		lineageTag: 3394a7c0-09ad-4aa2-af98-235a4d8289ef

	measure 'Cost per Attendee by Course' =
			
			VAR TotalCost = [Total Cost by Course]
			VAR TotalAttendees = [Total Attendees by Course]
			RETURN
			IF(TotalAttendees > 0, DIVIDE(TotalCost, TotalAttendees), 0)
		lineageTag: 244abb36-89c0-44ab-9dee-8fba1c2c8459

	measure 'Course Utilization Score' =
			
			VAR Frequency = [Course Frequency]
			VAR AvgAttendees = [Avg Attendees per Course]
			VAR ActiveMonths = [Course Active Months]
			RETURN
			Frequency * AvgAttendees * ActiveMonths
		lineageTag: 22ae0bfa-d463-41b1-9c03-271c2e70975e

