	measure 'Traffic Bureau % of Total Fines' = ```
			
			VAR TrafficTotal = [Traffic Bureau 12-Month Fine Total]
			VAR GrandTotal = 
			    CALCULATE(
			        SUM('___Summons'[TOTAL_PAID_AMOUNT]),
			        '___Summons'[ASSIGNMENT_FOUND] = TRUE()
			    )
			RETURN 
			DIVIDE(TrafficTotal, GrandTotal, 0) * 100
			```
		lineageTag: 1ba8b555-ff5e-47b9-813c-0d91c65c5d18

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Traffic Bureau Average Monthly Fines' =
			
			DIVIDE([Traffic Bureau 12-Month Fine Total], 13, 0)
		lineageTag: d9949222-c5b0-42c8-b3d9-80377abdeeeb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Traffic Bureau Monthly Target' = ```
			50000  // Adjust based on department goals
			
			```
		formatString: 0
		lineageTag: b72613a2-2ef2-4604-a679-d9bafc259848

	measure 'Traffic Bureau vs Target' = ```
			
			VAR MonthlyAvg = [Traffic Bureau Average Monthly Fines]
			RETURN
			SWITCH(
			    TRUE(),
			    MonthlyAvg >= [Traffic Bureau Monthly Target] * 1.1, "🎯 Exceeds Target",
			    MonthlyAvg >= [Traffic Bureau Monthly Target] * 0.9, "✅ Meets Target", 
			    MonthlyAvg >= [Traffic Bureau Monthly Target] * 0.75, "⚠️ Below Target",
			    "🔴 Significantly Below"
			)
			```
		lineageTag: e4b9f0fd-26b4-4107-9576-1f0252bd39bb

