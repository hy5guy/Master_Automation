	measure Patrol_Bureau_Parking_Previous_Month_Date =
			
			VAR CurrentDate = TODAY()
			VAR PreviousMonthStart = EOMONTH(CurrentDate, -2) + 1
			VAR PreviousMonthEnd = EOMONTH(CurrentDate, -1)
			RETURN
			CALCULATE(
			    COUNTROWS('summons_13month_trend'),
			    'summons_13month_trend'[WG2] = "Patrol Bureau",
			    'summons_13month_trend'[TYPE] = "P",
			    'summons_13month_trend'[ISSUE_DATE] >= PreviousMonthStart,
			    'summons_13month_trend'[ISSUE_DATE] <= PreviousMonthEnd
			)
		formatString: 0
		lineageTag: 4e3927b8-dcc5-4f70-b08c-1dcaa3997487

