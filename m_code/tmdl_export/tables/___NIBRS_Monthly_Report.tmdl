		lineageTag: 0d6dcfd5-2b04-4a0d-9ca6-510b94f24986

	measure 'Clearance Rate Numeric' = ```
			
			CALCULATE(
			    SUM( '___NIBRS_Monthly_Report'[MetricValue] ),
			    '___NIBRS_Monthly_Report'[Clearance and Crime Reporting Metrics] = "NIBRS Clearance Rate"
			)
			
			```
		lineageTag: 88e0cd19-b7ea-46ec-92c7-939e4f2a324c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

