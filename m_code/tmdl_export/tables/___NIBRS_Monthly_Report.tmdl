	measure 'NIBRS Chart Title' = ```
			
			VAR EndDate   = EOMONTH( TODAY(), -1 )
			VAR StartDate = EDATE( EndDate, -12 )
			RETURN
			"13-Month NIBRS Clearance Rate Trend: "
			  & FORMAT( StartDate, "MMMM yyyy" )
			  & " - "
			  & FORMAT( EndDate,   "MMMM yyyy" )
			
			```
		lineageTag: 0200210d-4e30-4a4d-b25a-14cbb2ef3814

	measure 'NIBRS Subtitle' = ```
			
			VAR EndDate   = EOMONTH( TODAY(), -1 )
			VAR StartDate = EDATE( EndDate, -12 )
			RETURN
			    FORMAT( StartDate, "MMMM yyyy" ) & " - " & FORMAT( EndDate, "MMMM yyyy" )
			
			```
		lineageTag: c1f9059b-c028-4d14-b3d6-86d3c2d53ebb

	measure LineChartTitle = ```
			
			"13-Month NIBRS Clearance Rate Trend"
			
			```
		lineageTag: 0b11afe5-4ded-4442-884c-3791c3c5e297

	measure LineChartSubtitle = ```
			
			VAR EndDate   = EOMONTH( TODAY(), -1 )    // last day of prior month
			VAR StartDate = EDATE( EndDate, -12 )      // 12 months before that
			RETURN
			FORMAT( StartDate, "MMMM yyyy" )
			    & " - "
			    & FORMAT( EndDate,   "MMMM yyyy" )
			
			```
		lineageTag: 99a95f2c-538b-464e-8db1-950195d6edbb

	column IsInRange = ```
			
			VAR MaxAvailableDate = MAX('___NIBRS_Monthly_Report'[MonthDate])
			VAR StartDate13Months = EDATE(MaxAvailableDate, -12)  // 13 months = current + 12 previous
			VAR CurrentRowDate = MAX('___NIBRS_Monthly_Report'[MonthDate])
			
			RETURN
			IF(
			    CurrentRowDate >= StartDate13Months && 
			    CurrentRowDate <= MaxAvailableDate,
			    1, 
			    0
			)
			```
