# Logs
logs/*.log
logs/*.err
logs/archive/

# Never commit copied .git trees (e.g. corruption recovery)
.git_corrupt_backup_*/

# Temporary files
_DropExports/*
!_DropExports/.gitkeep
tmpclaude-*-cwd
.tmp.driveupload/

# Output directories (testing/validation data)
# Use ** (not *) so git ignores the directory recursively; negation can then
# un-ignore .gitkeep files because the directories themselves are not ignored.
outputs/visual_exports/**
outputs/large_exports/**
outputs/misc/**
!outputs/visual_exports/.gitkeep
!outputs/large_exports/.gitkeep
!outputs/misc/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Backup files
*.bak
*.backup
*~

# Workspace files
*.code-workspace

# Chat logs (optional - uncomment to ignore)
# chatlogs/*.md

# Configuration backups
config/*.bak

# Power BI API credentials (contains secrets)
config/powerbi_api_config.json

# Local one-off exports / validation artifacts (keep out of git)
/*.csv
/*.m

# Diagnostic / test Excel files
*_DIAGNOSTIC_VERSION.xlsx
*_ROBUST_VERSION.xlsx
*_ULTRA_SIMPLE.xlsx

# Benchmark diagnostics
benchmark_diagnostic_*.json

# Pre-move backup files
*.premove

# Manifest files (Power BI export metadata)
_manifest.*

# Log files (repo-wide)
*.log

