VAR EndDate   = EOMONTH(TODAY(), -1)
VAR StartDate = EDATE(EndDate, -12)
RETURN
"Trend Analysis: " & FORMAT(StartDate, "MMMM yyyy") & " - " & FORMAT(EndDate, "MMMM yyyy")

Line Chart Subtitle Short = 
VAR EndDate   = EOMONTH(TODAY(), -1)
VAR StartDate = EDATE(EndDate, -12)
RETURN
FORMAT(StartDate, "MMM yyyy") & " - " & FORMAT(EndDate, "MMM yyyy")

Line Chart Title = "Incident Count by Date and Event Type"

Matrix Subtitle = 
VAR EndDate   = EOMONTH(TODAY(), -1)
VAR StartDate = EDATE(EndDate, -12)
RETURN
"Rolling 13-Month Overview (" &
    FORMAT(StartDate, "MMMM yyyy") & " - " & FORMAT(EndDate, "MMMM yyyy") & ")"

Matrix Title = "Use of Force Incident Matrix"

MonthHasData = 
VAR MonthTotal =
    CALCULATE (
        DISTINCTCOUNT ( '___Benchmark'[Report Key] ),
        ALL ( '___Benchmark'[EventType] )
    )
RETURN
MonthTotal


Most Frequent Event Type = 
VAR LastMonth = EOMONTH(TODAY(), -1)
VAR FirstMonth = EDATE(LastMonth, -12)
VAR EventCounts = 
    ADDCOLUMNS(
        VALUES(___DimEventType[EventType]),
        "@Count", CALCULATE(
            DISTINCTCOUNT(___Benchmark[Report Key]),
            ___Benchmark[MonthStart] >= FirstMonth,
            ___Benchmark[MonthStart] <= LastMonth
        )
    )
VAR MaxCount = MAXX(EventCounts, [@Count])
VAR TopEvent = MAXX(FILTER(EventCounts, [@Count] = MaxCount), ___DimEventType[EventType])
RETURN
    TopEvent & " (" & FORMAT(MaxCount, "#,0") & ")"

Officers_Count = 
VAR CurrentMonth = SELECTEDVALUE(___DimMonth[MonthStart])
VAR CurrentEventType = SELECTEDVALUE(___DimEventType[EventType])
VAR Result = 
    CALCULATE(
        SUM(___Benchmark[# of Officers Involved]),
        TREATAS({CurrentMonth}, ___Benchmark[MonthStart]),
        ___Benchmark[EventType] = CurrentEventType
    )
RETURN
    IF(ISBLANK(Result), 0, Result)

Peak Incident Count = 
MAXX(
    ALLSELECTED(___DimMonth[MonthLabel]),
    MAXX(
        ALLSELECTED(___DimEventType[EventType]),
        [IncidentCount]
    )
)

Peak Incidents = 
MAXX(
    ALL(___DimMonth[MonthLabel]),
    [IncidentCount]
)

Peak Month = 
VAR MaxCount = MAXX(ALL(___DimMonth[MonthLabel]), [IncidentCount])
VAR PeakMonth = 
    MAXX(
        FILTER(
            ALL(___DimMonth[MonthLabel]),
            [IncidentCount] = MaxCount
        ),
        ___DimMonth[MonthLabel]
    )
RETURN
"Peak: " & PeakMonth & " (" & FORMAT(MaxCount, "#,0") & " incidents)"

Peak Month Indicator = 
VAR MaxCount = 
    MAXX(
        ALLSELECTED(___DimMonth[MonthLabel]),
        MAXX(
            ALLSELECTED(___DimEventType[EventType]),
            [IncidentCount]
        )
    )
VAR PeakDetails = 
    FILTER(
        ADDCOLUMNS(
            CROSSJOIN(
                ALL(___DimMonth[MonthLabel]),
                ALL(___DimEventType[EventType])
            ),
            "@Count", [IncidentCount]
        ),
        [@Count] = MaxCount
    )
VAR PeakMonth = MAXX(PeakDetails, ___DimMonth[MonthLabel])
VAR PeakEventType = MAXX(PeakDetails, ___DimEventType[EventType])
RETURN
"Peak: " & PeakMonth & " (" & PeakEventType & " - " & FORMAT(MaxCount, "#,0") & " incidents)"

Peak Month Text = 
VAR PeakCount = [Peak Incident Count]
VAR PeakMonthValue = 
    CALCULATE(
        SELECTEDVALUE(___DimMonth[MonthLabel]),
        FILTER(
            ALL(___DimMonth[MonthLabel]),
            CALCULATE([IncidentCount]) = PeakCount
        )
    )
RETURN
"Peak: " & PeakMonthValue & " (" & FORMAT(PeakCount, "#,0") & " incidents)"

PeakMonthIndicatorSimple = 
VAR MaxCount = 
    CALCULATE(
        [IncidentCount],
        TOPN(
            1,
            ALLSELECTED(___DimMonth[MonthLabel], ___DimEventType[EventType]),
            [IncidentCount],
            DESC
        )
    )
VAR Result = 
    CONCATENATEX(
        TOPN(
            1,
            ALLSELECTED(___DimMonth[MonthLabel], ___DimEventType[EventType]),
            [IncidentCount],
            DESC
        ),
        ___DimMonth[MonthLabel] & " (" & ___DimEventType[EventType] & " - " & FORMAT([IncidentCount], "#,0") & " incidents)",
        ", "
    )
RETURN
    "Peak: " & Result

Subjects_Count = 
VAR CurrentMonth = SELECTEDVALUE(___DimMonth[MonthStart])
VAR CurrentEventType = SELECTEDVALUE(___DimEventType[EventType])
VAR Result = 
    CALCULATE(
        SUM(___Benchmark[# of Subjects]),
        TREATAS({CurrentMonth}, ___Benchmark[MonthStart]),
        ___Benchmark[EventType] = CurrentEventType
    )
RETURN
    IF(ISBLANK(Result), 0, Result)

Total Incidents Rolling 13 = 
VAR LastMonth = EOMONTH(TODAY(), -1)
VAR FirstMonth = EDATE(LastMonth, -12)
RETURN
CALCULATE(
    DISTINCTCOUNT(___Benchmark[Report Key]),
    ___Benchmark[MonthStart] >= FirstMonth,
    ___Benchmark[MonthStart] <= LastMonth
)