Avg Incidents Per Month = 
VAR LastMonth = EOMONTH(TODAY(), -1)
VAR FirstMonth = EDATE(LastMonth, -12)
VAR Total = [Total Incidents Rolling 13]
RETURN
    DIVIDE(Total, 13, 0)

BM MoM Change = 
VAR CurrentCount = [IncidentCount]
VAR PriorMonthDate = 
    CALCULATE(
        MAX(___DimMonth[MonthStart]),
        DATEADD(___DimMonth[MonthStart], -1, MONTH)
    )
VAR PriorCount = 
    CALCULATE(
        [IncidentCount],
        ___DimMonth[MonthStart] = PriorMonthDate
    )
VAR Change = CurrentCount - PriorCount
RETURN
    IF(ISBLANK(PriorCount), BLANK(), Change)

BM MoM Change % = 
VAR Change = [BM MoM Change]
VAR PriorMonthDate = 
    CALCULATE(
        MAX(___DimMonth[MonthStart]),
        DATEADD(___DimMonth[MonthStart], -1, MONTH)
    )
VAR PriorCount = 
    CALCULATE(
        [IncidentCount],
        ___DimMonth[MonthStart] = PriorMonthDate
    )
RETURN
    IF(PriorCount = 0 || ISBLANK(PriorCount), BLANK(), DIVIDE(Change, PriorCount))

BM_Rolling13_Count = 
VAR LastFullMonth = EOMONTH(TODAY(), -1)
VAR FirstMonth = EOMONTH(LastFullMonth, -12) + 1
RETURN
CALCULATE(
    DISTINCTCOUNT(___Benchmark[Report Number]),
    ___Benchmark[MonthStart] >= FirstMonth,
    ___Benchmark[MonthStart] <= LastFullMonth
)

BM_Rolling13_Count_Zero = 
VAR LastFullMonthEnd   = EOMONTH(TODAY(), -1)                  // Oct 31, 2025
VAR FirstMonthStart    = EOMONTH(LastFullMonthEnd, -12) + 1   // Nov 1, 2024
RETURN
COALESCE(
    CALCULATE(
        DISTINCTCOUNT(___Benchmark[Report Number]),
        ___Benchmark[Incident Date] >= FirstMonthStart,
        ___Benchmark[Incident Date] <= LastFullMonthEnd
    ),
    0
)

BM_YoY_Change = 
VAR CurrentCount = [BM_Rolling13_Count]
VAR PriorYearStart = DATEADD(DATEADD(EOMONTH(TODAY(), -1), -12, MONTH), -12, MONTH) + 1
VAR PriorYearEnd = EOMONTH(TODAY(), -13)
VAR PriorCount = 
    CALCULATE(
        DISTINCTCOUNT(___Benchmark[Report Number]),
        ___Benchmark[Incident Date] >= PriorYearStart,
        ___Benchmark[Incident Date] <= PriorYearEnd
    )
RETURN
    IF(PriorCount = 0, BLANK(), DIVIDE(CurrentCount - PriorCount, PriorCount))

Donut Subtitle = 
VAR EndDate   = EOMONTH(TODAY(), -1)
VAR StartDate = EDATE(EndDate, -12)
RETURN
"13-Month Period: " & FORMAT(StartDate, "MMM yyyy") & " - " & FORMAT(EndDate, "MMM yyyy")

Donut Subtitle Short = 
VAR EndDate   = EOMONTH(TODAY(), -1)
VAR StartDate = EDATE(EndDate, -12)
RETURN
FORMAT(StartDate, "MMM yy") & " - " & FORMAT(EndDate, "MMM yy")

Donut Subtitle with Count = 
VAR EndDate   = EOMONTH(TODAY(), -1)
VAR StartDate = EDATE(EndDate, -12)
VAR TotalIncidents = [IncidentCount_13Month]
RETURN
FORMAT(StartDate, "MMM yyyy") & " - " & FORMAT(EndDate, "MMM yyyy") & 
" | Total: " & FORMAT(TotalIncidents, "#,0")

Donut Title = "Incident Distribution by Event Type"

Donut Title = "Incident Distribution by Event Type"

IncidentCount = 
VAR Result = DISTINCTCOUNT(___Benchmark[Report Key])
RETURN 
    IF(ISBLANK(Result), 0, Result)

IncidentCount_13Month = 
VAR LastMonth = EOMONTH(TODAY(), -1)
VAR FirstMonth = EDATE(LastMonth, -12)
RETURN
    CALCULATE(
        DISTINCTCOUNT(___Benchmark[Report Key]),
        ___DimMonth[MonthStart] >= FirstMonth,
        ___DimMonth[MonthStart] <= LastMonth
    )

IncidentCount_Forced = 
VAR CurrentEventType = SELECTEDVALUE(___DimEventType[EventType])
RETURN
    CALCULATE(
        DISTINCTCOUNT(___Benchmark[Report Key]),
        ___Benchmark[EventType] = CurrentEventType
    )

IncidentCount_NEW = 
IF(
    HASONEVALUE(___DimMonth[MonthStart]) && HASONEVALUE(___DimEventType[EventType]),
    // Cell-level: specific month + event type
    VAR Result = DISTINCTCOUNT(___Benchmark[Report Key])
    RETURN IF(ISBLANK(Result), 0, Result),
    // Total-level: sum the individual cells
    SUMX(
        VALUES(___DimMonth[MonthStart]),
        VAR CurrentMonth = ___DimMonth[MonthStart]
        RETURN
            SUMX(
                VALUES(___DimEventType[EventType]),
                VAR CurrentEvent = ___DimEventType[EventType]
                VAR CellCount = 
                    CALCULATE(
                        DISTINCTCOUNT(___Benchmark[Report Key]),
                        ___DimMonth[MonthStart] = CurrentMonth,
                        ___DimEventType[EventType] = CurrentEvent
                    )
                RETURN IF(ISBLANK(CellCount), 0, CellCount)
            )
    )
)

Line Chart Avg Incidents Per Month = 
VAR TotalIncidents = 
    CALCULATE(
        [IncidentCount],
        ALL(___DimMonth[MonthLabel])
    )
VAR MonthCount = DISTINCTCOUNT(___DimMonth[MonthLabel])
RETURN
    DIVIDE(TotalIncidents, MonthCount, 0)

